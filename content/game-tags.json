{
  "_meta": {
    "description": "Best-for tags for all 50 games, used for frontend filtering and recommendations",
    "tag_definitions": {
      "solo-friendly": "Plays well with 1 player",
      "great-for-2": "Excellent 2-player experience",
      "family-friendly": "Easy to teach, fun for mixed ages",
      "date-night": "Good for 2 players, moderate length, engaging interaction",
      "party-night": "Supports 5+ players, social and lively",
      "brain-burner": "Deep strategy, heavy thinking",
      "quick-play": "Max play time 30 minutes or less",
      "gateway-game": "Perfect first modern board game",
      "cooperative": "Players work together against the game",
      "competitive": "Players compete against each other",
      "hidden-roles": "Bluffing or hidden identity element",
      "deck-building": "Build your card engine during play",
      "area-control": "Control territory or regions",
      "word-game": "Word-based or communication-based",
      "engine-building": "Build a scoring engine over time",
      "tile-laying": "Place tiles to build a map or pattern",
      "negotiation": "Trading and deal-making between players",
      "narrative": "Storytelling or thematic adventure"
    }
  },
